# ===========================================
# Ecommerce Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ecommerce_db
DATABASE_URL=postgresql://ecommerce_user:your_secure_password_here@localhost:5432/ecommerce_db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
PORT=3001
APP_NAME=Ecommerce Platform
APP_URL=http://localhost:3000

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your_jwt_secret_key_min_32_chars_here
JWT_EXPIRATION=7d
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# Frontend URLs
# ===========================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ===========================================
# Email Configuration (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# Stripe Payment Gateway
# ===========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# AWS S3 Configuration (File Uploads)
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=ecommerce-uploads
AWS_REGION=us-east-1

# ===========================================
# Domain & SSL
# ===========================================
DOMAIN_NAME=yourdomain.com
DOMAIN_EMAIL=admin@yourdomain.com

# ===========================================
# Docker Specific
# ===========================================
COMPOSE_PROJECT_NAME=ecommerce
